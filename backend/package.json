{
  "name": "wiom-finance-autopilot",
  "version": "9.0.0",
  "description": "AP automation: source-specific orchestrators + shared validation services",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/**/*.test.js",

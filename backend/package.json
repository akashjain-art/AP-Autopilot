  },
  "dependencies": {
    "pg": "^8.13.0",
    "ioredis": "^5.4.0",
    "googleapis": "^144.0.0",
    "express": "^4.21.0",
    "axios": "^1.7.0",
    "fuse.js": "^7.0.0",
    "uuid": "^10.0.0",
    "cron": "^3.1.0",
    "pdf-parse": "^1.1.1",
    "winston": "^3.14.0",
    "p-limit": "^3.1.0",
    "bottleneck": "^2.19.5"
  }
}
